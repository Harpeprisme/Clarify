generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String?
  googleId     String?   @unique
  avatarUrl    String?
  role         String    @default("READER") // ADMIN | READER
  isEmailVerified        Boolean  @default(false)
  emailVerificationToken String?  @unique
  mustChangePassword     Boolean  @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  budgets      Budget[]
  accounts     Account[]
  categories   Category[]
  rules        CategoryRule[]
  passwordResetTokens PasswordResetToken[]
  recurringTransactions RecurringTransaction[]
  forecastSettings      ForecastSettings?
}

model AccountType {
  id        String   @id // e.g., "COURANT", "LIVRET_A", "PEA", "CTO"
  name      String
  group     String   // COURANT | EPARGNE | INVESTISSEMENT | CREDIT
  accounts  Account[]
}

model Account {
  id                  Int           @id @default(autoincrement())
  name                String
  type                String        @default("COURANT") // Foreign key to AccountType.id
  accountType         AccountType?  @relation(fields: [type], references: [id])
  initialBalance      Float         @default(0)        // Solde réel au jour de la 1ère importation
  initialBalanceDate  DateTime?                        // Date de référence du solde initial
  userId              Int
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  imports             ImportHistory[]
  createdAt           DateTime      @default(now())
}

model Category {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  color        String         @default("#6B7280")
  icon         String         @default("tag")
  isDefault    Boolean        @default(false)
  userId       Int?           // null for global defaults, int for custom user categories
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  rules        CategoryRule[]
  budgets      Budget[]
  recurringTransactions RecurringTransaction[]
}

model CategoryRule {
  id         Int      @id @default(autoincrement())
  keyword    String
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     Int?     // Link to user if it's a personal rule
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  priority   Int      @default(0)
  createdAt  DateTime @default(now())
}

model Transaction {
  id             Int      @id @default(autoincrement())
  date           DateTime
  description    String            // Cleaned, human-readable name
  rawDescription String?           // Original bank description (nullable for legacy)
  amount         Float
  type           String   // INCOME | EXPENSE | TRANSFER
  balance        Float?
  accountId      Int
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  categoryId     Int?
  category       Category? @relation(fields: [categoryId], references: [id])
  isInternal     Boolean  @default(false)
  isPointed      Boolean  @default(false) // Rapprochement bancaire
  importedAt     DateTime @default(now())
  notes          String?

  @@index([accountId, date])
  @@index([type])
  @@index([categoryId])
}

model Budget {
  id         Int      @id @default(autoincrement())
  amount     Float
  month      String   // format: YYYY-MM
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([categoryId, month, userId])
}

model ImportHistory {
  id         Int      @id @default(autoincrement())
  filename   String
  accountId  Int
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  rowCount   Int
  importedAt DateTime @default(now())
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
}

model RecurringTransaction {
  id               Int       @id @default(autoincrement())
  userId           Int
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  description      String
  averageAmount    Float
  frequency        String    // MONTHLY | WEEKLY | QUARTERLY | ANNUAL
  nextExpectedDate DateTime?
  lastSeenDate     DateTime
  occurrences      Int       @default(0)
  confidence       Float     @default(0)
  isConfirmed      Boolean   @default(false)
  isActive         Boolean   @default(true)
  categoryId       Int?
  category         Category? @relation(fields: [categoryId], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ForecastSettings {
  id                       Int    @id @default(autoincrement())
  userId                   Int    @unique
  user                     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlySalary            Float?
  safetyBuffer             Float  @default(200)
  detectionMinOccurrences  Int    @default(2)
  detectionAmountTolerance Float  @default(15)
  detectionDayTolerance    Int    @default(5)
}
