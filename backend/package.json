{
  "name": "openbank-backend",
  "version": "1.0.0",
  "description": "OpenBank - Personal Finance API",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:migrate": "npx prisma@6.0.0 migrate dev",
    "db:seed": "node src/seed.js",
    "db:reset-prod": "node src/scripts/reset_db.js",
    "db:reset": "npx prisma@6.0.0 migrate reset --force",
    "postinstall": "prisma generate",
    "test": "jest --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^4.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.2.0",
    "fast-xml-parser": "^5.5.8",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "iconv-lite": "^0.7.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "ofx-js": "^0.2.0",
    "papaparse": "^5.4.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pdf2pic": "^3.2.0",
    "prisma": "^6.0.0",
    "qif2json": "^0.4.0",
    "resend": "^6.9.3",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
